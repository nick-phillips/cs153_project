/*
 * biomarker-discovery Nextflow configuration
 */

params {
    // Inputs
    response_ids   = "${projectDir}/conf/response_ids.txt"
    feature_file   = "${projectDir}/data/x-all_v4.pkl"
    response_file  = "${projectDir}/data/responses_primary_v4.pkl"

    // Outputs
    outdir = "${projectDir}/results"

    // Cross-validation
    n_folds = 5

    // Resources
    n_threads = 1
    max_local_cpus = 128

    // Container image (update tag as needed)
    container = 'biomarker-discovery:latest'

    // Python environment (for local execution without container)
    uv_venv = "${projectDir}/.venv"
}

process {
    // Retry a failing task up to three additional times, then skip it
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
    maxRetries = 3
    retryDelay = '15s'  // Wait before retrying to allow I/O contention to clear

    withLabel: 'process_low' {
        cpus = 1
        memory = '4 GB'
        time = '2h'
    }

    withLabel: 'process_medium' {
        cpus = 4
        memory = '16 GB'
        time = '6h'
    }

    withLabel: 'process_high' {
        cpus = 1
        memory = '12 GB'
        time = '12h'
    }
}

profiles {
    standard {
        executor {
            submitRateLimit = '1/1s'
        }
        process.executor = 'local'
        process.beforeScript = """
            set -euo pipefail
            export PYTHONNOUSERSITE=1
            export PYTHONPATH=$projectDir
            export UV_PROJECT_ENVIRONMENT=$params.uv_venv
            if ! command -v uv >/dev/null 2>&1; then
                echo "[nextflow] ERROR: uv is required but was not found on PATH" >&2
                exit 1
            fi
            ml openblas/0.3.26
            export OMP_NUM_THREADS=1
            export MKL_NUM_THREADS=1
            export OPENBLAS_NUM_THREADS=1
        """
    }

    slurm {
        executor {
            queueSize = 200
            
            submitRateLimit = '1/2s'  // Limit to 1 job submission every 2 seconds
        }
        process {
            executor = 'slurm'
            queue = 'corsello,dkurtz,arasha,normal,owners,sfgf'
            maxRetries = 3
            retryDelay = '2 min'
            beforeScript = """
                set -euo pipefail
                export PYTHONNOUSERSITE=1
                export PYTHONPATH=$projectDir
                export UV_PROJECT_ENVIRONMENT=$params.uv_venv
                export OMP_NUM_THREADS=$params.n_threads
                export MKL_NUM_THREADS=$params.n_threads
                export OPENBLAS_NUM_THREADS=$params.n_threads
                export NUMEXPR_NUM_THREADS=$params.n_threads
                ml openblas/0.3.26
            """
        }
    }

    docker {
        executor {
            cpus = params.max_local_cpus
            submitRateLimit = '1/2s'  // Limit to 1 job submission every 2 seconds
        }
        docker.enabled = true
        // Code is baked into container at /app; no mount needed
        docker.runOptions = "-u \$(id -u):\$(id -g) --memory=16g -e OMP_NUM_THREADS=${params.n_threads} -e MKL_NUM_THREADS=${params.n_threads} -e OPENBLAS_NUM_THREADS=${params.n_threads} -e NUMEXPR_NUM_THREADS=${params.n_threads}"
        process.container = params.container
    }

    singularity {
        executor {
            cpus = params.max_local_cpus
            submitRateLimit = '1/4s'  // Limit to 1 job submission every 2 seconds
        }
        singularity.enabled = true
        singularity.autoMounts = true
        // Code is baked into container at /app; no bind needed
        singularity.runOptions = "--env OMP_NUM_THREADS=${params.n_threads},MKL_NUM_THREADS=${params.n_threads},OPENBLAS_NUM_THREADS=${params.n_threads},NUMEXPR_NUM_THREADS=${params.n_threads}"
        process.container = params.container
    }

    // Combined profiles for SLURM + container
    slurm_docker {
        executor {
            queueSize = 499
            submitRateLimit = '1/2s'  // Limit to 1 job submission every 2 seconds
        }
        docker.enabled = true
        // Code is baked into container at /app; no mount needed
        docker.runOptions = "-e OMP_NUM_THREADS=${params.n_threads} -e MKL_NUM_THREADS=${params.n_threads} -e OPENBLAS_NUM_THREADS=${params.n_threads} -e NUMEXPR_NUM_THREADS=${params.n_threads}"
        process {
            executor = 'slurm'
            queue = 'corsello,dkurtz,arasha,normal,owners,sfgf'
            container = params.container
            maxRetries = 3
            retryDelay = '2 min'
        }
    }

    slurm_singularity {
        executor {
            queueSize = 499
            submitRateLimit = '1/4s'  // Limit to 1 job submission every 2 seconds
        }
        singularity.enabled = true
        singularity.autoMounts = true
        // Code is baked into container at /app; no bind needed
        singularity.runOptions = "--env OMP_NUM_THREADS=${params.n_threads},MKL_NUM_THREADS=${params.n_threads},OPENBLAS_NUM_THREADS=${params.n_threads},NUMEXPR_NUM_THREADS=${params.n_threads}"
        process {
            executor = 'slurm'
            queue = 'corsello,dkurtz,arasha,normal,owners,sfgf'
            container = params.container
            maxRetries = 3
            retryDelay = '2 min'
        }
    }
}

manifest {
    name = 'biomarker-discovery'
    version = '2.0.0'
    description = 'biomarker-discovery'
    mainScript = 'main.nf'
    nextflowVersion = '>=21.10.0'
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_dag.svg"
    overwrite = true
}
